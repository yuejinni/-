{
  "manifest_version": 3,
  "name": "报关文件生成器",
  "version": "1.0.0",
  "description": "筋斗云调拨单 → 自动生成出口报关单/发票/装箱单",

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "*://*.jdy.com/*",
    "http://localhost:5008/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.jdy.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "报关文件生成器"
  }
}
